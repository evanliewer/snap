<div class="max-w-md mx-auto bg-white p-8 rounded-xl shadow-sm border border-slate-200">
  <h1 class="text-2xl font-bold mb-6">Create your Snap account</h1>
  <%= form_with model: @user, url: signup_path, local: true, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :name, class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :name, required: true, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
    </div>
    <div>
      <%= f.label :email_address, class: "block text-sm font-medium mb-1" %>
      <%= f.email_field :email_address, required: true, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
    </div>
    <div>
      <%= f.label :password, class: "block text-sm font-medium mb-1" %>
      <%= f.password_field :password, required: true, minlength: 8, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
      <p class="text-xs text-slate-500 mt-1">At least 8 characters.</p>
    </div>
    <%= f.submit "Sign up", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 rounded-md" %>
  <% end %>
  <p class="mt-4 text-sm text-slate-500 text-center">
    Already have an account? <%= link_to "Log in", login_path, class: "text-indigo-600 hover:underline" %>
  </p>
</div>
