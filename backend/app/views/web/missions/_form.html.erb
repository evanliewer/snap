<%= form_with model: [@game, mission], local: true, class: "space-y-4 bg-white p-6 rounded-xl border border-slate-200" do |f| %>
  <div>
    <%= f.label :title, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :title, required: true, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
  </div>
  <div>
    <%= f.label :description, class: "block text-sm font-medium mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
  </div>
  <div class="grid sm:grid-cols-3 gap-4">
    <div>
      <%= f.label :mission_type, class: "block text-sm font-medium mb-1" %>
      <%= f.select :mission_type, Mission::TYPES, {}, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
    </div>
    <div>
      <%= f.label :points, class: "block text-sm font-medium mb-1" %>
      <%= f.number_field :points, min: 0, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
    </div>
    <div>
      <%= f.label :bonus_points, class: "block text-sm font-medium mb-1" %>
      <%= f.number_field :bonus_points, min: 0, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
    </div>
  </div>
  <div class="grid sm:grid-cols-3 gap-4">
    <div>
      <%= f.label :mission_category_id, "Category", class: "block text-sm font-medium mb-1" %>
      <%= f.select :mission_category_id, options_from_collection_for_select(@game.mission_categories, :id, :name, mission.mission_category_id), { include_blank: "— none —" }, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
    </div>
    <div>
      <%= f.label :position, class: "block text-sm font-medium mb-1" %>
      <%= f.number_field :position, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
    </div>
    <div>
      <%= f.label :max_submissions_per_team, "Max per team", class: "block text-sm font-medium mb-1" %>
      <%= f.number_field :max_submissions_per_team, min: 1, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
    </div>
  </div>
  <div class="grid sm:grid-cols-3 gap-2 text-sm">
    <label class="flex items-center gap-2"><%= f.check_box :required %> Required mission</label>
    <label class="flex items-center gap-2"><%= f.check_box :repeatable %> Repeatable</label>
    <label class="flex items-center gap-2"><%= f.check_box :requires_location %> Requires location</label>
  </div>
  <%= f.submit (mission.persisted? ? "Save" : "Create mission"), class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
<% end %>
