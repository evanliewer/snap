<%= form_with model: [@game, team], local: true, class: "space-y-4 bg-white p-6 rounded-xl border border-slate-200" do |f| %>
  <div>
    <%= f.label :name, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :name, required: true, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
  </div>
  <div>
    <%= f.label :color, class: "block text-sm font-medium mb-1" %>
    <%= f.color_field :color, value: team.color.presence || "#4F46E5", class: "h-10 w-20 border border-slate-300 rounded-md" %>
  </div>
  <%= f.submit (team.persisted? ? "Save" : "Add team"), class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
<% end %>
