<%= form_with model: [@game, category], url: (category.persisted? ? game_mission_category_path(@game, category) : game_mission_categories_path(@game)), local: true, class: "space-y-4 bg-white p-6 rounded-xl border border-slate-200" do |f| %>
  <div>
    <%= f.label :name, class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :name, required: true, class: "w-full border border-slate-300 rounded-md px-3 py-2" %>
  </div>
  <div>
    <%= f.label :color, class: "block text-sm font-medium mb-1" %>
    <%= f.color_field :color, value: category.color.presence || "#10B981", class: "h-10 w-20 border border-slate-300 rounded-md" %>
  </div>
  <div>
    <%= f.label :position, class: "block text-sm font-medium mb-1" %>
    <%= f.number_field :position, class: "w-32 border border-slate-300 rounded-md px-3 py-2" %>
  </div>
  <%= f.submit (category.persisted? ? "Save" : "Add"), class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
<% end %>
