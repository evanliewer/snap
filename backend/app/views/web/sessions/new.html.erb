<div class="max-w-md mx-auto bg-white p-8 rounded-xl shadow-sm border border-slate-200">
  <h1 class="text-2xl font-bold mb-6">Log in to Snap</h1>
  <%= form_with url: login_path, method: :post, local: true, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :email_address, class: "block text-sm font-medium mb-1" %>
      <%= f.email_field :email_address, required: true, autofocus: true, class: "w-full border border-slate-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-indigo-500" %>
    </div>
    <div>
      <%= f.label :password, class: "block text-sm font-medium mb-1" %>
      <%= f.password_field :password, required: true, class: "w-full border border-slate-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-indigo-500" %>
    </div>
    <%= f.submit "Log in", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 rounded-md" %>
  <% end %>
  <p class="mt-4 text-sm text-slate-500 text-center">
    No account? <%= link_to "Sign up", signup_path, class: "text-indigo-600 hover:underline" %>
  </p>
</div>
